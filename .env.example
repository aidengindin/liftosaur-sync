# Liftosaur API key — Settings → API Keys → Create API Key (requires premium)
LIFTOSAUR_API_KEY=lftsk_your_key_here

# ---------------------------------------------------------------------------
# Intervals.icu (optional)
# ---------------------------------------------------------------------------

# Set to false to disable even if credentials are present (default: true)
INTERVALS_ENABLED=true

# Settings → API Keys (generate a new key)
INTERVALS_API_KEY=your_intervals_api_key_here

# Your Intervals.icu athlete ID (visible in the URL after logging in, e.g. i12345)
INTERVALS_ATHLETE_ID=i00000

# ---------------------------------------------------------------------------
# Strava (optional)
# Register your app at https://www.strava.com/settings/api
# ---------------------------------------------------------------------------

# Set to false to disable even if credentials are present (default: true)
STRAVA_ENABLED=true

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Base URL used to build the Strava OAuth redirect URI
BASE_URL=http://localhost:3000

# Port to listen on (default: 3000)
PORT=3000

# Protect /sync and /status with a bearer token (optional but recommended)
SYNC_SECRET=

# Path to the SQLite database used for sync state (default: ./sync-state.db)
DB_PATH=sync-state.db

# Timezone for converting Liftosaur's UTC timestamps to local time before syncing.
# Uses IANA timezone names (e.g. America/New_York, Europe/London, Asia/Tokyo).
# If unset, timestamps are sent as-is (UTC, which will show the wrong local time).
TIMEZONE=America/New_York

# Friel weight training load calculation for Intervals.icu
# Set to true to enable TSS-style load scores on each workout
ENABLE_LOAD_CALCULATION=false
# Rolling window in weeks for computing average session tonnage (default: 6)
LOAD_WINDOW_WEEKS=6
